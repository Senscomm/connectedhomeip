    output_path + "hal/core/hal-core.a",
    output_path + "hal/proc/hal-proc.a",
    output_path + "hal/drivers/core/hal-drivers-core.a",
    output_path + "hal/fs/hal-fs.a",
    output_path + "hal/fs/patch/hal-fs-patch.a",
    output_path + "hal/drivers/serial/hal-drivers-serial.a",
    output_path + "hal/drivers/rtc/hal-drivers-rtc.a",
    output_path + "hal/drivers/clk/hal-drivers-clk.a",
    output_path + "hal/drivers/pinctrl/hal-drivers-pinctrl.a",
    output_path + "hal/drivers/ble/hal-drivers-ble.a",
    output_path + "hal/drivers/ble/priv/hal-drivers-ble-priv.a",
