import("//build_overrides/build.gni")
import("//build_overrides/chip.gni")
import("//build_overrides/scm1612s.gni")

import("${build_root}/config/defaults.gni")
import("${chip_root}/src/platform/device.gni")
import("${scm1612s_sdk_build_root}/scm1612s_executable.gni")
import("${scm1612s_sdk_build_root}/scm1612s_sdk.gni")

assert(current_os == "freertos")

scm1612s_project_dir = "${chip_root}/examples/lighting-app/senscomm/scm1612s"
examples_plat_dir = "${chip_root}/examples/platform/senscomm/scm1612s"
elf_name = "chip-scm1612s-lighting-app-example.out"

declare_args() {
  # Dump memory usage at link time.
  chip_print_memory_usage = true

  # PIN code for PASE session establishment.
  setup_pin_code = 20202021

  # Monitor & log memory usage at runtime.
  enable_heap_monitoring = false

  # Build update app
  build_update_image = false
}

action("build_wise_sdk") {
  script = "${scm1612s_sdk_build_root}/build-wise-sdk.py"

  output_path = root_out_dir + "/wise-sdk/"

  args = [
    rebase_path("${scm1612s_sdk_build_root}", root_build_dir),
    "scm1612s_matter_defconfig",
    "--output-path",
    output_path
#    rebase_path(output_path, root_build_dir)
  ]

  inputs = [
    "${scm1612s_sdk_build_root}/build-wise-sdk.py",
    "${scm1612s_sdk_root}/include/generated/timestamp_autogenerated.h"
    # Add other inputs here if needed
  ]

  outputs = [
    output_path + "timestamp_autogenerated.h",
    output_path + "kernel/kernel.a",
    output_path + "api/api.a",
    #output_path + "/app/app.a",
    output_path + "kernel/FreeRTOS/kernel-FreeRTOS.a",
    output_path + "kernel/FreeRTOS-ext/kernel-FreeRTOS-ext.a",
    output_path + "kernel/cmsis-freertos/kernel-cmsis-freertos.a",
    output_path + "kernel/freebsd/kernel-freebsd.a",
    output_path + "hal/arch/ndsv5/hal-arch-ndsv5.a",
    output_path + "hal/soc/scm2010/hal-soc-scm2010.a",
    output_path + "hal/board/scm2010-evb-qfn40/hal-board-scm2010-evb-qfn40.a",
    output_path + "hal/drivers/spi-flash/hal-drivers-spi-flash.a",
    output_path + "hal/drivers/wlan/hal-drivers-wlan.a",
    output_path + "hal/drivers/wlan/senscomm/prv/hal-drivers-wlan-senscomm-prv.a",
    output_path + "hal/drivers/rf/hal-drivers-rf.a",
    output_path + "hal/drivers/watchdog/hal-drivers-watchdog.a",
    output_path + "lib/cli/lib-cli.a",
    output_path + "lib/stdlib-ext/lib-stdlib-ext.a",
    output_path + "lib/proc/lib-proc.a",
    output_path + "lib/serial/lib-serial.a",
    output_path + "lib/net/lib-net.a",
    output_path + "lib/fs/lib-fs.a",
    output_path + "lib/lwip/lib-lwip.a",
    output_path + "lib/net80211/lib-net80211.a",
    output_path + "lib/ifconfig/lib-ifconfig.a",
    output_path + "lib/libifconfig/lib-libifconfig.a",
    output_path + "lib/cjson/lib-cjson.a",
    output_path + "lib/hostap/wpa_supplicant/lib-hostap-wpa_supplicant.a",
    output_path + "lib/mbedtls-2.28.10/library/lib-mbedtls-2.28.10-library.a",
    output_path + "lib/ble/nimble_port/lib-ble-nimble_port.a",
    output_path + "lib/ble/nimble_host/lib-ble-nimble_host.a",
    output_path + "lib/tinycrypt/lib-tinycrypt.a",
    output_path + "lib/scm_mcuboot/lib-scm_mcuboot.a",
